# sonic-gnmi Development Container
#
# Bakes in all SONiC dependencies so developers (and AI agents) don't need to
# manually fetch artifacts from Azure DevOps pipelines.
#
# Pre-installed:
#   - libyang 1.0.73 + libnl (from sonic-buildimage.common_libs)
#   - libswsscommon + python3-swsscommon (from sonic-swss-common)
#   - sonic_yang_models Python wheel (built from source)
#   - sonic-mgmt-common (built from source, source kept at /opt/sonic-mgmt-common)
#   - redis-server, protobuf-compiler, pytest, jsonpatch
#
# Build context expects a deps/ directory containing the required .deb files
# and sonic_yang_models wheel. In CI this is populated by DownloadPipelineArtifact;
# locally it is populated by: make -f dev.mk fetch-deps
#
# Usage: see dev.mk

FROM sonicdev-microsoft.azurecr.io:443/sonic-slave-bookworm:latest

ARG BUILD_BRANCH=master

# ── System tools ──────────────────────────────────────────────────────────────
RUN sudo apt-get update -qq && \
    sudo apt-get install -y --no-install-recommends \
        redis-server \
        protobuf-compiler \
        git \
    && sudo rm -rf /var/lib/apt/lists/*

# ── Python tools ──────────────────────────────────────────────────────────────
RUN sudo pip3 install --break-system-packages -U pytest jsonpatch jinja2 wheel setuptools

# ── Install dep debs from build context ───────────────────────────────────────
COPY deps/ /tmp/sonic-deps/

RUN set -ex; \
    sudo apt-get -y purge libnl-3-dev libnl-route-3-dev 2>/dev/null || true; \
    sudo dpkg -i /tmp/sonic-deps/libyang_1.0.73_amd64.deb; \
    sudo dpkg -i /tmp/sonic-deps/libyang-dev_1.0.73_amd64.deb; \
    sudo dpkg -i /tmp/sonic-deps/libnl-3-200_*.deb; \
    sudo dpkg -i /tmp/sonic-deps/libnl-genl-3-200_*.deb; \
    sudo dpkg -i /tmp/sonic-deps/libnl-route-3-200_*.deb; \
    sudo dpkg -i /tmp/sonic-deps/libnl-nf-3-200_*.deb; \
    sudo apt-get --fix-broken install -y; \
    sudo dpkg -i /tmp/sonic-deps/libswsscommon_1.0.0_amd64.deb; \
    sudo dpkg -i /tmp/sonic-deps/libswsscommon-dev_1.0.0_amd64.deb; \
    sudo dpkg -i /tmp/sonic-deps/python3-swsscommon_1.0.0_amd64.deb; \
    sudo pip3 install --break-system-packages /tmp/sonic-deps/sonic_yang_models-*.whl; \
    rm -rf /tmp/sonic-deps

# ── Configure Redis ────────────────────────────────────────────────────────────
RUN sudo sed -ri 's/^# unixsocket/unixsocket/' /etc/redis/redis.conf && \
    sudo sed -ri 's/^unixsocketperm .../unixsocketperm 777/' /etc/redis/redis.conf && \
    sudo sed -ri 's/redis-server\.sock/redis.sock/' /etc/redis/redis.conf

# ── Build + install sonic-mgmt-common ─────────────────────────────────────────
# Source is kept at /opt/sonic-mgmt-common because sonic-gnmi's Makefile
# references MGMT_COMMON_DIR for YANG files and patches.
RUN set -ex; \
    git clone --depth=1 --branch ${BUILD_BRANCH} \
        https://github.com/sonic-net/sonic-mgmt-common.git /opt/sonic-mgmt-common; \
    git config --global --add safe.directory /opt/sonic-mgmt-common; \
    cd /opt/sonic-mgmt-common && \
        NO_TEST_BINS=1 dpkg-buildpackage -rfakeroot -b -us -uc; \
    sudo dpkg -i /opt/sonic-mgmt-common_1.0.0_amd64.deb; \
    # Fix postinst bug: script references a path only valid inside sonic-buildimage tree \
    echo '#!/usr/bin/env bash' | sudo tee /var/lib/dpkg/info/sonic-mgmt-common-codegen.postinst; \
    sudo dpkg -i /opt/sonic-mgmt-common-codegen_1.0.0_amd64.deb; \
    rm -f /opt/sonic-mgmt-common_*.deb /opt/sonic-mgmt-common-codegen_*.deb \
          /opt/sonic-mgmt-common_*.buildinfo /opt/sonic-mgmt-common_*.changes

# /workspace/sonic-mgmt-common is the path sonic-gnmi's Makefile expects
# (MGMT_COMMON_DIR = $(TOPDIR)/../sonic-mgmt-common, TOPDIR = /workspace/sonic-gnmi)
RUN sudo mkdir -p /workspace && \
    sudo ln -s /opt/sonic-mgmt-common /workspace/sonic-mgmt-common && \
    git config --global --add safe.directory /workspace/sonic-gnmi && \
    git config --global --add safe.directory /workspace/sonic-mgmt-common

WORKDIR /workspace/sonic-gnmi
